{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nexara",
  "version": "0.3.0",
  "identifier": "com.nexara.app",
  "build": {
    "beforeDevCommand": "powershell -NoProfile -Command \"Set-Location ..\\frontend; npm run dev\"",
    "beforeBuildCommand": "powershell -NoProfile -Command \"Set-Location ..\\frontend; npm run build\"",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../frontend/out"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "Nexara",
        "width": 1480,
        "height": 920,
        "minWidth": 1080,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "nsis",
    "icon": [
      "icons/icon.png"
    ],
    "publisher": "Nexara",
    "category": "Education",
    "shortDescription": "AI-powered educational assistant",
    "longDescription": "Nexara is a modern AI-powered educational assistant that helps students with scheduling, learning, and document management.",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "resources": [],
    "externalBin": [],
    "copyright": "",
    "license": "",
    "licenseFile": "",
    "createUpdaterArtifacts": false
  }
}
