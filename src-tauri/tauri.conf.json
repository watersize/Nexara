{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nexara",
  "version": "0.2.0",
  "identifier": "com.schoolmate.prototype",
  "build": {
    "beforeDevCommand": "powershell -NoProfile -Command \"Set-Location ..; python -m http.server 1420 --directory web\"",
    "beforeBuildCommand": "",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "Nexara",
        "width": 1480,
        "height": 920,
        "minWidth": 1080,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
