{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "veyo.ai",
  "version": "1.2.2",
  "identifier": "ai.veyo.desktop",
  "build": {
    "beforeDevCommand": "powershell -NoProfile -Command \"Set-Location ..\\frontend; npm run dev\"",
    "beforeBuildCommand": "powershell -NoProfile -Command \"Set-Location ..\\frontend; npm run build\"",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../frontend/out"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "veyo.ai",
        "width": 1480,
        "height": 920,
        "minWidth": 1080,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "nsis",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "publisher": "veyo.ai",
    "category": "Productivity",
    "shortDescription": "Desktop-first professional workspace",
    "longDescription": "veyo.ai is a modern professional workspace with hybrid notes, planning, AI chat, graph navigation, and technical drafting tools.",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "resources": [],
    "externalBin": [],
    "copyright": "",
    "license": "",
    "licenseFile": "",
    "createUpdaterArtifacts": false
  }
}
